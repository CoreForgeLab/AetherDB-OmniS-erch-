# ==============================================================
# .gitignore — 世界观数据库管理系统
# ==============================================================

# ===================== Agent / AI 相关（不提交）=====================
.agents/
.agent/
.codex/
.claude/
CODEX_PROJECT_CONTEXT.md
AGENTS.md

# ===================== 敏感配置与凭据（不提交）=====================
.env
.env.*
api_keys.json*
.api_keys.json
config.local.yaml

# ===================== 数据库（不提交，自动创建）=====================
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
chroma_db/

# ===================== Python 构建缓存与虚拟环境 ====================
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# ===================== 日志（不提交）=====================
logs/
*.log

# ===================== 本地临时文件与备份（不提交）=====================
_start_temp.py
tmp_content.py
backup_project.ps1
backup/
backups/

# ===================== IDE / 操作系统元文件 ====================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini
