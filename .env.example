# ==============================================================
# .env.example — 环境变量配置模板
# 复制此文件为 .env 到项目根目录，填入实际值后生效
# ==============================================================

# ===================== API 密钥 =====================
# 代码读取优先级:
#   ADMIN_API_KEY → NOVEL_ADMIN_KEY → 自动生成随机密钥
#   USER_API_KEY  → NOVEL_API_KEY  → 自动生成随机密钥
# 留空则每次启动自动生成，服务端终端会打印出来
ADMIN_API_KEY=
USER_API_KEY=

# ===================== LLM 抽取器配置 =====================
# 以下变量对应 config.yaml 中 extractor 段的字段。
# 当前代码读取的是 config.yaml / 传入字典，并非直接读环境变量，
# 但在此列出作为参考，方便在 .env 中统一管理。

# LLM 后端类型: openai_compatible 或 ollama
EXTRACTOR_BACKEND=openai_compatible

# OpenAI 兼容后端
OPENAI_API_BASE=https://api.deepseek.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=deepseek-chat

# Ollama 后端
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_HOST=localhost:11434
